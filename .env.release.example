# Copy this file to  .env.release  (git-ignored) and fill in the values.
# scripts/release.sh sources it, so you only enter these once.

# GitHub token with 'repo' scope — used to publish the release.
# You can omit this if you run `gh auth login` instead (preferred; the token
# then lives in your OS keychain and the script reads it via `gh auth token`).
GH_TOKEN=

# Apple notarization. APPLE_APP_SPECIFIC_PASSWORD is an app-specific password
# from https://appleid.apple.com → Sign-In and Security → App-Specific Passwords.
# (Code signing itself uses the Developer ID identity in your login keychain.)
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=3U86H8PJF6
